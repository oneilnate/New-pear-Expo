{
  "name": "food-pod-expo",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && pnpm exec eslint --config eslint.config.expo.js src/",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size-limit": "size-limit",
    "build:web": "expo export --platform web",
    "verify:fast": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm build:web && pnpm size-limit",
    "verify": "pnpm verify:fast && pnpm exec playwright test e2e/screenshots",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.2.2",
    "@tanstack/react-query": "^5.100.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-glass-effect": "~0.1.9",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.17",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-expo": "^1.0.0",
    "msw": "^2.13.4",
    "react-test-renderer": "19.1.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "vitest-native": "0.3.0"
  },
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/spec-drift-check.js"
  }
}
